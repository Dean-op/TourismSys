<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.RestaurantinfoDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.RestaurantinfoEntity" id="restaurantinfoMap">
        <result property="restaurantname" column="restaurantname"/>
        <result property="address" column="address"/>
        <result property="avgprice" column="avgprice"/>
        <result property="reserveprice" column="reserveprice"/>
        <result property="introduce" column="introduce"/>
        <result property="restaurantphoto" column="restaurantphoto"/>
        <result property="thumbsupnum" column="thumbsupnum"/>
        <result property="crazilynum" column="crazilynum"/>
        <result property="clicktime" column="clicktime"/>
        <result property="clicknum" column="clicknum"/>
		<result property="content" column="content"/>
		<result property="merchantusername" column="merchantusername"/>
		<result property="merchantname" column="merchantname"/>
    </resultMap>



    <select id="selectListView"
		resultType="com.entity.view.RestaurantinfoView" >

		SELECT  restaurantinfo.* FROM restaurantinfo  restaurantinfo
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.RestaurantinfoView" >
		SELECT * FROM restaurantinfo  restaurantinfo <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

</mapper>
