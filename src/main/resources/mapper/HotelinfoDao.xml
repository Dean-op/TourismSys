<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.HotelinfoDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.HotelinfoEntity" id="hotelinfoMap">
        <result property="hotelname" column="hotelname"/>
        <result property="hoteltype" column="hoteltype"/>
        <result property="address" column="address"/>
        <result property="roomtype" column="roomtype"/>
        <result property="price" column="price"/>
        <result property="telephone" column="telephone"/>
        <result property="introduce" column="introduce"/>
        <result property="hotelphoto" column="hotelphoto"/>
        <result property="thumbsupnum" column="thumbsupnum"/>
        <result property="crazilynum" column="crazilynum"/>
        <result property="clicktime" column="clicktime"/>
        <result property="clicknum" column="clicknum"/>
        <result property="content" column="content"/>
        <result property="merchantusername" column="merchantusername"/>
        <result property="merchantname" column="merchantname"/>
    </resultMap>



    <select id="selectListView"
		resultType="com.entity.view.HotelinfoView" >

		SELECT  hotelinfo.* FROM hotelinfo  hotelinfo
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.HotelinfoView" >
		SELECT * FROM hotelinfo  hotelinfo <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

</mapper>
